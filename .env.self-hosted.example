# ─── Copia questo file in .env.local e compila i valori ───────────────────────
# Guida completa: SELF_HOSTING.md

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_questa_password_sicura

# ─── PostgREST JWT ────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
SUPABASE_JWT_SECRET=genera-una-stringa-random-di-almeno-32-caratteri

# JWT anon e service role — generati dalla tua istanza PostgREST
# Vedi: https://postgrest.org/en/stable/tutorials/tut0.html#step-3-create-database-objects
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Supabase-compatibili (self-hosted via PostgREST) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Database diretto (per RAG ingestor Python) ───────────────────────────────
DATABASE_URL=postgresql://postgres:cambia_questa_password_sicura@localhost:5432/aicomply

# ─── Ollama (LLM locale — sostituisce Vertex AI) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Feature flags ────────────────────────────────────────────────────────────
AICOMPLY_MODE=self-hosted
AICOMPLY_RAG_PROVIDER=ollama

# ─── Vertex AI — lasciare VUOTI in modalità self-hosted ───────────────────────
VERTEX_PROJECT_ID=
VERTEX_LOCATION=
VERTEX_SERVICE_ACCOUNT_JSON=
